#!/bin/sh

printf '\n==> Running pre-push verification...\n'

if ! ./gradlew -q assemble; then
  printf '[ERROR] Compilation failed.\n'
  exit 1
fi

if ! ./gradlew -q staticAnalysis; then
  printf '[ERROR] Spotless / Checkstyle / PMD violations found.\n'
  exit 1
fi

if ! ./gradlew -q javadoc; then
  printf '[ERROR] Javadoc errors found.\n'
  exit 1
fi

printf '[OK] Push allowed: code compiles, passes quality checks, and Javadoc is valid.\n'
exit 0
