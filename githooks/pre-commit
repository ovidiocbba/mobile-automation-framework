#!/bin/bash

echo "==> Running pre-commit checks..."

if ! ./gradlew spotlessCheck; then
echo ""
read -p "Format code with spotlessApply? [y/N]: " -n 1 -r < /dev/tty
echo ""

if [[ $REPLY =~ ^[Yy]$ ]]; then
./gradlew spotlessApply && echo "[OK] Code formatted. Re-add and commit again."
else
echo "[ERROR] Commit aborted."
fi

exit 1
fi

echo "[OK] Pre-commit checks passed."
